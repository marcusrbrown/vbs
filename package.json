{
  "name": "@marcusrbrown/vbs",
  "version": "0.0.0",
  "private": true,
  "description": "A chronological Star Trek viewing guide with progress tracking",
  "keywords": [
    "star-trek",
    "viewing-guide",
    "chronological",
    "progress-tracker",
    "local-first"
  ],
  "license": "MIT",
  "author": "Marcus R. Brown <vbs@mrbro.dev>",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "fix": "eslint --fix",
    "lint": "eslint",
    "lint-staged": "lint-staged",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,js,jsx,tsx,css,md,json,yaml,yml}": [
      "eslint --fix"
    ]
  },
  "prettier": "@bfra.me/prettier-config",
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@bfra.me/eslint-config": "0.51.1",
    "@bfra.me/prettier-config": "0.16.9",
    "@bfra.me/tsconfig": "0.13.1",
    "@types/d3": "7.4.3",
    "@types/jsdom": "27.0.0",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.6",
    "@vitest/ui": "4.1.6",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jiti": "2.7.0",
    "jsdom": "27.4.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "simple-git-hooks": "2.13.1",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.1.6"
  },
  "packageManager": "pnpm@10.33.4"
}
